# Required PostgreSQL connection string.
DATABASE_URL=postgres://shortlink:password@localhost:5432/shortlink

# Optional PostgreSQL TLS and SQL logging.
DATABASE_SSL=false
DATABASE_LOGGING=false

# Optional. Used to render short URLs in production.
# Example: https://go.example.com
PRIVATE_BASE_URL=

# Optional. Node adapter bind host for built production output.
HOST=127.0.0.1

# Optional. Node adapter graceful shutdown timeout in seconds.
SHUTDOWN_TIMEOUT=1

# Required. Used to sign login session cookies.
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
