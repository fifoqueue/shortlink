# Required PostgreSQL connection string.
DATABASE_URL=postgres://shortlink:password@localhost:5432/shortlink
# For docs/docker-compose.yaml with PgBouncer, use:
# DATABASE_URL=postgres://shortlink:replace-this-password@pgbouncer:5432/shortlink

# Optional. Used by docs/docker-compose.yaml to initialize bundled PostgreSQL.
POSTGRES_DB=shortlink
POSTGRES_USER=shortlink
POSTGRES_PASSWORD=replace-this-password

# Optional. Used by docs/docker-compose.yaml to run PgBouncer in front of PostgreSQL.
DB_HOST=postgres
DB_PORT=5432
DB_USER=shortlink
DB_PASSWORD=replace-this-password
DB_NAME=shortlink
POOL_MODE=transaction
MAX_CLIENT_CONN=10000
DEFAULT_POOL_SIZE=50
MIN_POOL_SIZE=0
RESERVE_POOL_SIZE=10

# Optional PostgreSQL TLS and SQL logging.
DATABASE_SSL=false
DATABASE_LOGGING=false
DATABASE_POOL_MAX=10
DATABASE_POOL_MIN=0
DATABASE_POOL_ACQUIRE_MS=30000
DATABASE_POOL_IDLE_MS=10000
# Set true when DATABASE_URL points to PgBouncer.
DATABASE_PGBOUNCER=false
DATABASE_APPLICATION_NAME=shortlink
DATABASE_STATEMENT_TIMEOUT_MS=0
DATABASE_IDLE_TRANSACTION_TIMEOUT_MS=0

# Optional. Set to true to let Sequelize ALTER existing tables from models.
DATABASE_SYNC_ALTER=false

# Optional Redis shared cache, pub/sub invalidation, and Redis Streams queue.
REDIS_URL=
REDIS_KEY_PREFIX=shortlink

# Optional high-throughput redirect tracking knobs.
SETTINGS_CACHE_TTL_MS=5000
PERMISSION_GROUP_CACHE_TTL_MS=5000
CLICK_QUEUE_BACKEND=memory
CLICK_QUEUE_DB_BATCH_SIZE=250
CLICK_QUEUE_BATCH_SIZE=5000
CLICK_QUEUE_MEMORY_LIMIT=200000
CLICK_QUEUE_METADATA_CONCURRENCY=128
CLICK_QUEUE_FLUSH_MS=10
CLICK_QUEUE_HEADER_BYTES=4096
CLICK_QUEUE_SHUTDOWN_DRAIN_MS=2000
CLICK_QUEUE_REDIS_STREAM=click-events
CLICK_QUEUE_REDIS_GROUP=shortlink-click-writers
CLICK_QUEUE_REDIS_CONSUMER=
CLICK_QUEUE_REDIS_MAXLEN=1000000
REDIRECT_LINK_CACHE_TTL_MS=5000
REDIRECT_LINK_CACHE_LIMIT=20000
SESSION_USER_CACHE_TTL_MS=5000
SESSION_USER_CACHE_LIMIT=10000

# Optional ClickHouse analytics mirror for large click event volumes.
ANALYTICS_CLICKHOUSE_URL=
ANALYTICS_CLICKHOUSE_DATABASE=
ANALYTICS_CLICKHOUSE_TABLE=shortlink_click_events
ANALYTICS_CLICKHOUSE_USERNAME=
ANALYTICS_CLICKHOUSE_PASSWORD=
ANALYTICS_CLICKHOUSE_AUTO_CREATE=true
CLICKHOUSE_BACKFILL_BATCH_SIZE=10000
CLICKHOUSE_BACKFILL_START_ID=0
CLICKHOUSE_BACKFILL_END_ID=
CLICKHOUSE_BACKFILL_TRUNCATE=false

# Optional. Used by docs/docker-compose.yaml to initialize bundled ClickHouse.
CLICKHOUSE_DB=shortlink
CLICKHOUSE_USER=shortlink
CLICKHOUSE_PASSWORD=replace-this-clickhouse-password
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1

# Optional. Used to render short URLs in production.
# Example: https://go.example.com
PRIVATE_BASE_URL=

# Optional. Node adapter bind host for built production output.
HOST=127.0.0.1

# Optional. Node adapter graceful shutdown timeout in seconds.
SHUTDOWN_TIMEOUT=1

# Optional. Number of adapter-node workers when using yarn start:cluster.
WEB_CONCURRENCY=

# Optional. Runtime ABI plugin polling for Docker-mounted user plugins.
USER_PLUGIN_WATCH=true

# Required. Used to sign login session cookies.
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
